<Window x:Class="TaskHub.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskHub" Height="750" Width="600" 
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3F3F3F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BB86FC"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1E1E1E"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Adăugare Task Nou" Foreground="#BB86FC" Grid.Row="0" Margin="0,0,0,10" BorderBrush="#333333">
            <StackPanel Margin="10">
                <Label x:Name="lblTitlu" Content="_Titlu Task (3-15 caractere):" Target="{Binding ElementName=txtTitlu}"/>
                <TextBox x:Name="txtTitlu" Height="25" Background="#2D2D2D" Foreground="White" BorderBrush="#3F3F3F" VerticalContentAlignment="Center" CaretBrush="White"/>
                <TextBlock x:Name="errTitlu" Text="Titlu invalid!" Foreground="#FF6B6B" FontSize="11" Visibility="Collapsed"/>

                <Label x:Name="lblCategorie" Content="_Categorie:" Target="{Binding ElementName=cmbCategorie}"/>
                <ComboBox x:Name="cmbCategorie" Height="30">
                    <ComboBoxItem Content="Personal"/>
                    <ComboBoxItem Content="Work"/>
                    <ComboBoxItem Content="Scoala"/>
                </ComboBox>

                <Label x:Name="lblZile" Content="_Termen (zile):" Target="{Binding ElementName=txtZile}"/>
                <TextBox x:Name="txtZile" Height="25" Background="#2D2D2D" Foreground="White" BorderBrush="#3F3F3F" VerticalContentAlignment="Center" CaretBrush="White"/>
                <TextBlock x:Name="errZile" Text="Introduceți un număr valid!" Foreground="#FF6B6B" FontSize="11" Visibility="Collapsed"/>

                <UniformGrid Columns="2" Margin="0,15,0,0">
                    <Button x:Name="btnAdauga" Content="Salvează Task" Click="btnAdauga_Click" Margin="5" Height="35" Background="#BB86FC" Foreground="Black" FontWeight="Bold" BorderThickness="0"/>
                    <Button x:Name="btnReset" Content="Reset" Click="btnReset_Click" Margin="5" Height="35" Background="#333333" Foreground="White" BorderBrush="#444444"/>
                </UniformGrid>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Filtrare" Grid.Row="1" Margin="0,0,0,10" Foreground="#03DAC6" BorderBrush="#333333">
            <DockPanel Margin="5">
                <Button x:Name="btnIncarca" Content="Refresh" Click="btnIncarca_Click" DockPanel.Dock="Right" Width="80" Margin="5,0,0,0" Background="#333333" Foreground="White"/>
                <Button x:Name="btnCauta" Content="Caută" Click="btnCauta_Click" DockPanel.Dock="Right" Width="80" Margin="5,0,0,0" Background="#03DAC6" Foreground="Black" FontWeight="Bold"/>
                <TextBox x:Name="txtCautare" Height="25" Background="#2D2D2D" Foreground="White" BorderBrush="#3F3F3F" VerticalContentAlignment="Center" CaretBrush="White"/>
            </DockPanel>
        </GroupBox>

        <DataGrid x:Name="dgTaskuri" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                  Background="#1E1E1E" RowBackground="#252525" AlternatingRowBackground="#2D2D2D" 
                  Foreground="White" BorderBrush="#333333" HorizontalGridLinesBrush="#333333" 
                  VerticalGridLinesBrush="#333333" CanUserAddRows="False" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Titlu" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Categorie" Binding="{Binding Category}" Width="100"/>
                <DataGridTextColumn Header="Termen" Binding="{Binding DueDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                <DataGridCheckBoxColumn Header="Ok" Binding="{Binding IsCompleted}" Width="40"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>